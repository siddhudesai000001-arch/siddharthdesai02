# ============================================================
# SidLocker - Environment Variables
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# ============================================================

# Database (SQLite - local file)
DATABASE_URL="file:./sidlocker.db"

# NextAuth Secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# LOGIN CREDENTIALS
# Set the email/username and hashed password here.
# 
# To generate a bcrypt hash of your password, run:
#   node scripts/hash-password.js yourpassword
#
# WARNING: NEVER store plain-text passwords here.
# ============================================================

# Allowed email for login
AUTH_EMAIL="your-email@example.com"

# Allowed username for login  
AUTH_USERNAME="your-username"

# Bcrypt hashed password (use hash-password.js script to generate)
AUTH_PASSWORD_HASH="$2a$12$REPLACE_THIS_WITH_ACTUAL_BCRYPT_HASH"

# ============================================================
# App Settings
# ============================================================
APP_NAME="SidLocker"
UPLOAD_DIR="public/uploads"
MAX_FILE_SIZE_MB="50"
ALLOWED_EXTENSIONS="pdf,jpg,jpeg,png,webp,doc,docx,txt"

# Watermark text shown during preview
WATERMARK_TEXT="Private Document - Siddharth"
